# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Supabase DB (for local dev + migrations)
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Resend (email)
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL=noreply@appexhibition.sa

# AI (Vercel AI Gateway)
AI_GATEWAY_API_KEY=YOUR_GATEWAY_KEY
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
# Phase V1.1 — per-user daily AI spend cap (USD). Calls beyond this throw
# RateLimitError and the UI renders AIFallback reason='rate_limited'.
AI_DAILY_BUDGET_USD=1.0

# Sentry
SENTRY_DSN=https://YOUR_DSN@sentry.io/YOUR_PROJECT
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_DSN@sentry.io/YOUR_PROJECT

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=YOUR_CRON_SECRET

# Platform bank account (shown to clients for escrow deposits)
PLATFORM_IBAN=SA0000000000000000000000
PLATFORM_BANK_NAME=البنك الأهلي السعودي
PLATFORM_ACCOUNT_HOLDER=شركة تطبيق المعارض

# Feature flags (UX Plan v2). Default OFF — uncomment to enable per surface.
# Source: lib/feature-flags.ts. Full guide: ai-documents/PHASE-U-FLAG-GUIDE.md.
# NEXT_PUBLIC_FF_AI_CONFIDENCE=true   # AI confidence badge + MarketRange + AIDisagree + AIFallback
# NEXT_PUBLIC_FF_RFQ_SINGLE=true      # Single-screen RFQ form + Smart Defaults
# NEXT_PUBLIC_FF_TRUST=true           # IdentityBadges + TrustBar
# NEXT_PUBLIC_FF_HIJRI=true           # Hijri-first date display
# NEXT_PUBLIC_FF_PRAYER=true          # PrayerTimesWidget
# NEXT_PUBLIC_FF_NUMERALS=true        # Arabic-Indic numerals (١٢٣)
# NEXT_PUBLIC_FF_CONCIERGE=true       # "مُدار بواسطة Elmaared" badge + copy
# NEXT_PUBLIC_FF_CELEBRATION=true     # Confetti modal on milestones
# NEXT_PUBLIC_FF_PDPL=true            # PDPL consent banner on first visit
